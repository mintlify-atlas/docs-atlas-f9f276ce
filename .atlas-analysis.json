  "keyFeatures": [
    "Email Search with Holehe integration",
    "EXIF metadata extraction from images, videos, and PDFs",
    "Cryptographic hash generation and verification",
    "IP geolocation and network information lookup",
    "Username search across 300+ platforms with Sherlock",
    "International phone number information search",
    "Async task processing with Celery",
    "Responsive Bootstrap 5 interface with dark/light mode",
    "Comprehensive security features (CSP, HSTS, CSRF protection)"
  ],
